{
    "name": "youcord",
    "private": "true",
    "version": "1.21.4",
    "description": "Everything Discord doesn't build, we create",
    "main": "dist/js/main.js",
    "homepage": "https://github.com/nightcordlegit/youcord",
    "bugs": {
        "url": "https://github.com/nightcordlegit/youcord/issues"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/nightcordlegit/youcord.git"
    },
    "license": "GPL-3.0-or-later",
    "author": "Equicord",
    "scripts": {
        "build": "pnpm depCheck && pnpm generatePluginJson && node --require=./scripts/suppressExperimentalWarnings.js scripts/build/build.mjs",
        "buildStandalone": "pnpm build --standalone",
        "buildDesktop": "tsx scripts/build/buildDesktop.mts",
        "package": "pnpm run buildDesktop && pnpm run buildStandalone && electron-builder --config electron-builder.config.cjs",
        "package:dir": "pnpm run buildDesktop && pnpm run buildStandalone && electron-builder --config electron-builder.config.cjs --dir",
        "buildWeb": "node --require=./scripts/suppressExperimentalWarnings.js scripts/build/buildWeb.mjs",
        "buildWebStandalone": "pnpm buildWeb --standalone",
        "buildReporter": "pnpm buildWebStandalone --reporter --skip-extension",
        "buildReporterDesktop": "pnpm build --reporter",
        "start": "pnpm run buildDesktop && pnpm run buildStandalone && electron .",
        "start:dev": "pnpm run buildDesktop --dev && pnpm run buildStandalone && electron .",
        "watch": "pnpm build --watch",
        "dev": "pnpm watch",
        "watchWeb": "pnpm buildWeb --watch",
        "generateDevsList": "tsx scripts/generateDevsList.ts",
        "generatePluginJson": "tsx scripts/generatePluginList.ts plugins.json",
        "generateEquicordPluginJson": "tsx scripts/generatePluginList.ts --equicord plugins.json",
        "generateVencordPluginJson": "tsx scripts/generatePluginList.ts --vencord plugins.json",
        "generateTypes": "tspc --emitDeclarationOnly --declaration --outDir packages/vencord-types --allowJs false",
        "inject": "node scripts/runInstaller.mjs -- --install",
        "uninject": "node scripts/runInstaller.mjs -- --uninstall",
        "repair": "node scripts/runInstaller.mjs -- --repair",
        "lint": "eslint",
        "lint-styles": "stylelint \"src/**/*.css\" --ignore-pattern src/userplugins",
"lint-styles:fix": "stylelint \"src/**/*.css\" --ignore-pattern src/userplugins --fix",
        "lint:fix": "pnpm lint --fix",
        "test": "pnpm buildStandalone && pnpm lint:fix && pnpm lint-styles:fix && pnpm lint-styles && pnpm generatePluginJson",
"testAll": "pnpm buildStandalone && pnpm testTsc && pnpm lint:fix && pnpm lint-styles && pnpm generatePluginJson",
        "testWeb": "pnpm lint:fix && pnpm buildWeb && pnpm testTsc",
        "testTsc": "tsc --noEmit",
        "depCheck": "node scripts/depCheck.mjs"
    },
    "dependencies": {
        "@ffmpeg/ffmpeg": "^0.12.15",
        "@ffmpeg/util": "^0.12.2",
        "@intrnl/xxhash64": "^0.1.2",
        "@song-spotlight/api": "^2.2.0",
        "@streamparser/json": "^0.0.22",
        "@types/less": "^3.0.8",
        "@types/stylus": "^0.48.43",
        "@types/tinycolor2": "^1.4.6",
        "@vap/core": "0.0.12",
        "@vap/shiki": "0.10.5",
        "discord": "^0.8.2",
        "fflate": "^0.8.3",
        "gifenc": "github:mattdesl/gifenc#64842fca317b112a8590f8fef2bf3825da8f6fe3",
        "idb": "8.0.3",
        "jsqr": "1.4.0",
        "monaco-editor": "^0.56.0",
        "nanoid": "^5.1.16",
        "native-file-system-adapter": "^3.0.1",
        "p-limit": "^7.3.1",
        "usercss-meta": "^0.12.0",
        "virtual-merge": "^1.0.2",
        "yaml-js": "^0.3.1"
    },
    "devDependencies": {
        "@electron/asar": "^4.2.0",
        "@fal-works/esbuild-plugin-global-externals": "^2.1.2",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/adm-zip": "^0.5.8",
        "@types/chrome": "^0.1.43",
        "@types/diff": "^7.0.2",
        "@types/lodash": "^4.17.24",
        "@types/node": "^24.13.3",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@types/yazl": "^3.3.1",
        "@vencord/discord-types": "link:packages\\discord-types",
        "app-builder-lib": "^26.15.3",
        "arrpc-bun": "^1.4.0",
        "diff": "^8.0.4",
        "dotenv": "^17.4.2",
        "electron": "^41.10.1",
        "electron-builder": "^26.15.3",
        "electron-updater": "^6.8.9",
        "esbuild": "^0.27.7",
        "eslint": "9.39.1",
        "eslint-import-resolver-alias": "^1.1.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-simple-header": "^1.2.2",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "eslint-plugin-unused-imports": "^4.4.1",
        "highlight.js": "11.11.1",
        "html-minifier-terser": "^7.2.0",
        "javascript-obfuscator": "^5.4.7",
        "minimatch": "^10.2.5",
        "moment": "^2.30.1",
        "puppeteer-core": "^24.43.1",
        "rcedit": "^5.0.2",
        "source-map-support": "^0.5.21",
        "standalone-electron-types": "^41.2.1",
        "stylelint": "^16.26.1",
        "stylelint-config-standard": "^39.0.1",
        "ts-patch": "^3.3.0",
        "ts-pattern": "^5.9.0",
        "tsx": "^4.23.0",
        "type-fest": "^5.8.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.63.0",
        "typescript-transform-paths": "^3.5.6",
        "ws": "^8.21.0",
        "zip-local": "^0.3.5"
    },
    "packageManager": "pnpm@11.11.0",
    "engines": {
        "node": ">=18"
    },
    "build": {
        "extends": null,
        "configFile": "electron-builder.config.cjs"
    }
}
